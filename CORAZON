<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>I Love You ❤</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: #000;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #stage {
    position: relative;
    width: 0;
    height: 0;
  }
  .ily {
    position: absolute;
    font-family: sans-serif;
    font-weight: 600;
    white-space: nowrap;
    color: #ea80b0;
    transform-origin: center center;
    pointer-events: none;
    will-change: transform, opacity, font-size;
  }
</style>
</head>
<body>
<div id="stage"></div>
<script>
(function () {
  const stage  = document.getElementById('stage');
  const N      = 300;
  const SCALE  = 15;
  const SPEED  = 0.004;
  const LABEL  = 'I love you';

  /* Ecuación paramétrica del corazón */
  function heart(t) {
    const x =  16 * Math.pow(Math.sin(t), 3);
    const y = -(13 * Math.cos(t)
              -  5 * Math.cos(2 * t)
              -  2 * Math.cos(3 * t)
              -      Math.cos(4 * t));
    return { x: x * SCALE, y: y * SCALE };
  }

  /* Crear elementos */
  const items = [];
  for (let i = 0; i < N; i++) {
    const el = document.createElement('span');
    el.className  = 'ily';
    el.textContent = LABEL;

    const baseSize  = 13 + Math.random() * 7;   /* 13–20 px */
    const offset    = (i / N) * Math.PI * 2;    /* distribuir en el perímetro */
    const speedMult = 0.7 + Math.random() * 0.6;/* velocidad ligeramente variada */
    const phase     = Math.random() * Math.PI * 2;

    stage.appendChild(el);
    items.push({ el, offset, baseSize, speedMult, phase });
  }

  let last = null;
  let elapsed = 0;

  function frame(ts) {
    if (!last) last = ts;
    const dt = (ts - last) / 1000;
    last = ts;
    elapsed += dt;

    for (let i = 0; i < N; i++) {
      const item = items[i];
      const t = item.offset + elapsed * SPEED * item.speedMult * Math.PI * 2;

      const { x, y } = heart(t);

      /* Pulso suave de tamaño y opacidad */
      const pulse   = 0.5 + 0.5 * Math.sin(elapsed * 1.8 + item.phase);
      const sz      = item.baseSize + pulse * 3;
      const opacity = 0.55 + pulse * 0.45;

      /* Brillo variable */
      const glow1 = Math.floor(8  + pulse * 6);
      const glow2 = Math.floor(16 + pulse * 12);

      item.el.style.cssText = `
        left: ${x}px;
        top: ${y}px;
        font-size: ${sz.toFixed(1)}px;
        opacity: ${opacity.toFixed(3)};
        transform: translate(-50%, -50%);
        text-shadow: 0 0 ${glow1}px #fff, 0 0 ${glow2}px #ea80b0, 0 0 ${glow2 * 2}px #ea80b0;
      `;
    }

    requestAnimationFrame(frame);
  }

  requestAnimationFrame(frame);
})();
</script>
</body>
</html>
